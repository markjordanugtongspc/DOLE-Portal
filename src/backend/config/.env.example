# ============================================================
# DOLE Iligan Portal — Supabase Configuration Template
# Copy this file to .env and fill in your actual values.
# ⚠️  The actual .env file is gitignored — never commit real keys!
# ============================================================

# Supabase Project URL
# Find this in: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Public Key (safe for frontend use — read-only public access)
# Find this in: Supabase Dashboard > Project Settings > API > anon public
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Supabase Service Role Key (server-side only — NEVER expose to client)
# Find this in: Supabase Dashboard > Project Settings > API > service_role
VITE_SUPABASE_SERVICE_ROLE=your_service_role_key_here

# Supabase Storage Bucket name for system card image uploads
VITE_SUPABASE_STORAGE_BUCKET=system-images
