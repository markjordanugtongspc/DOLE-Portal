# ============================================================
# DOLE Iligan Portal - Supabase Configuration Template
# Copy this file to .env and fill in your actual values.
# The actual .env file is gitignored. Never commit real keys.
# ============================================================

# Supabase Project URL
# Find this in: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Public Key
# This is the only Supabase key that should be exposed to frontend Vite code.
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Supabase Storage Bucket name for system card image uploads
VITE_SUPABASE_STORAGE_BUCKET=system-images

# Local migration runner only. Do not prefix server-side secrets with VITE_.
# Keep this value in .env.local or .env only, never in committed files.
# SUPABASE_DB_URL=your_local_database_connection_string_here
# MIGRATION_SQL_PATH=C:/secure/schema.sql